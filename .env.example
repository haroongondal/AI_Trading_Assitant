# Ollama (local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Database (SQLite for dev)
DATABASE_URL=sqlite+aiosqlite:///./data/trading_assistant.db

# RAG
CHROMA_PERSIST_DIR=./data/chroma
RAG_TOP_K=4

# Demo user
DEFAULT_USER_ID=default-user

# CORS (optional). Comma-separated origins; defaults include http://localhost:3000, http://127.0.0.1:3000
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Scheduler (twice daily). Default 08:00 and 18:00.
SCHEDULER_HOUR_1=8
SCHEDULER_MINUTE_1=0
SCHEDULER_HOUR_2=18
SCHEDULER_MINUTE_2=0

# WhatsApp (Meta Cloud API). Leave empty to skip WhatsApp delivery.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_RECIPIENT_PHONE=
# WHATSAPP_TEMPLATE_NAME=hello_world
