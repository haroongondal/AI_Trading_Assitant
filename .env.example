# Ollama (local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_TEMPERATURE=0.3
# OLLAMA_NUM_CTX=4096
# AGENT_MAX_TURNS=6

# Logging: INFO (default) or DEBUG for more noise
# LOG_LEVEL=INFO

# Database (SQLite for dev)
DATABASE_URL=sqlite+aiosqlite:///./data/trading_assistant.db

# RAG
CHROMA_PERSIST_DIR=./data/chroma
RAG_TOP_K=4

# Anonymous / dev user when the browser has no session cookie (shared demo portfolio)
DEFAULT_USER_ID=default-user

# --- Google OAuth (optional; all of the first four are required together) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# FRONTEND_URL=http://localhost:3000

# --- Session JWT (required when using Google sign-in) ---
# AUTH_JWT_SECRET=
# AUTH_JWT_ALGORITHM=HS256
# AUTH_JWT_EXPIRE_DAYS=7


# Scheduler: disabled by default for local chat responsiveness.
SCHEDULER_ENABLED=false
# Cron format: minute hour day month day_of_week (default: twice daily at 09:00 and 21:00)
SCHEDULER_CRON="0 9,21 * * *"


# WhatsApp (Meta Cloud API). Leave empty to skip WhatsApp delivery.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_RECIPIENT_PHONE=
# WHATSAPP_TEMPLATE_NAME=hello_world

# Email SMTP (Gmail-compatible). Leave creds empty to skip email delivery.
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_STARTTLS=true
# EMAIL_SMTP_USERNAME=your-email@gmail.com
# Use a Gmail App Password (16 chars), not your normal Google password.
# EMAIL_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# Optional sender address (defaults to EMAIL_SMTP_USERNAME)
# EMAIL_FROM=your-email@gmail.com
# Optional fallback recipient when user.email is not present
# EMAIL_DEFAULT_TO=alerts@yourdomain.com
