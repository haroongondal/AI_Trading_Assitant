# AWS credentials for boto3 / CLI (scripts/ssm_session.sh, provision scripts)
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
# Optional if you are using temporary credentials
# AWS_SESSION_TOKEN=REPLACE_ME

# Region for AWS CLI (required by scripts/ssm_session.sh)
AWS_REGION=us-east-1

# OCI API auth
OCI_USER_OCID=ocid1.user.oc1..REPLACE_ME
OCI_FINGERPRINT=REPLACE_ME
OCI_TENANCY_OCID=ocid1.tenancy.oc1..REPLACE_ME
OCI_REGION=us-ashburn-1

# Choose one OCI private key input method:
# 1) File path
OCI_PRIVATE_KEY_PATH=/absolute/path/to/oci_api_key.pem

# 2) Or inline private key content with literal \n separators
# OCI_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----

# Optional if your OCI private key is encrypted
# OCI_PRIVATE_KEY_PASSPHRASE=REPLACE_ME
